{
  "meta_version": "3.0.0",
  "system": {
    "name": "AgenOps",
    "purpose": "A governance-driven system of AI agents and reusable skills for software engineering lifecycle support, execution, and control.",
    "owner_role": "software-engineer-orchestrator"
  },
  "layers": {
    "core": {
      "path": "kit/core"
    },
    "skills": {
      "path": "kit/skills"
    },
    "state": {
      "path": "kit/state"
    },
    "runtime": {
      "path": "kit/runtime"
    },
    "validation": {
      "path": "kit/validation"
    },
    "security": {
      "path": "security"
    },
    "judging": {
      "path": "kit/judging"
    },
    "experience": {
      "path": "kit/experience"
    },
    "templates": {
      "path": "kit/templates"
    },
    "policies": {
      "path": "kit/policies"
    },
    "topology": {
      "path": "governance/topology"
    },
    "decision": {
      "path": "governance/decision"
    },
    "telemetry": {
      "path": "runtime/telemetry"
    },
    "economics": {
      "path": "governance/economics"
    },
    "gitops": {
      "path": "governance/gitops"
    },
    "learning": {
      "path": "learning"
    },
    "meta_model": {
      "path": "meta-model"
    }
  },
  "skills": {
    "manifest": "kit/skills/manifest.md",
    "contract": "kit/skills/skill-contract.md",
    "catalog": "kit/skills/skill-catalog.md"
  },
  "invariants": [
    {
      "id": "INV-001",
      "statement": "Only the orchestrator may write canonical state.",
      "severity": "critical",
      "enforcement": "state write validation",
      "evidence_required": true
    },
    {
      "id": "INV-002",
      "statement": "No artifact may be approved without an evidence bundle.",
      "severity": "critical",
      "enforcement": "approval gate validation",
      "evidence_required": true
    },
    {
      "id": "INV-003",
      "statement": "Security-sensitive actions require explicit permission and review.",
      "severity": "critical",
      "enforcement": "security permission check",
      "evidence_required": true
    },
    {
      "id": "INV-004",
      "statement": "All important runtime actions must emit telemetry.",
      "severity": "error",
      "enforcement": "telemetry emission check",
      "evidence_required": true
    },
    {
      "id": "INV-005",
      "statement": "Irreversible decisions require explicit decision records and stronger review.",
      "severity": "error",
      "enforcement": "decision framework validation",
      "evidence_required": true
    },
    {
      "id": "INV-006",
      "statement": "Reusable skills must be registered, versioned, and discoverable.",
      "severity": "error",
      "enforcement": "skills registry validation",
      "evidence_required": true
    }
  ],
  "relationships": [
    {
      "from": "core",
      "to": "skills",
      "mode": "reads",
      "allowed": true,
      "reason": "core uses reusable skills to orchestrate work."
    },
    {
      "from": "runtime",
      "to": "skills",
      "mode": "reads",
      "allowed": true,
      "reason": "runtime may invoke skills as governed capabilities."
    },
    {
      "from": "validation",
      "to": "skills",
      "mode": "reads",
      "allowed": true,
      "reason": "validation checks skill contracts and registry."
    },
    {
      "from": "judging",
      "to": "skills",
      "mode": "reads",
      "allowed": true,
      "reason": "judging may score outputs produced via skills."
    },
    {
      "from": "core",
      "to": "state",
      "mode": "reads",
      "allowed": true,
      "reason": "core reads shared state to coordinate roles."
    },
    {
      "from": "core",
      "to": "state",
      "mode": "writes",
      "allowed": false,
      "reason": "only orchestrator may write canonical state."
    },
    {
      "from": "validation",
      "to": "state",
      "mode": "validates",
      "allowed": true,
      "reason": "validation checks canonical state and artifacts."
    },
    {
      "from": "security",
      "to": "state",
      "mode": "observes",
      "allowed": true,
      "reason": "security reviews state and artifacts without mutating state."
    },
    {
      "from": "decision",
      "to": "core",
      "mode": "governs",
      "allowed": true,
      "reason": "decision framework standardizes agent choices."
    },
    {
      "from": "telemetry",
      "to": "learning",
      "mode": "learns",
      "allowed": true,
      "reason": "observability feeds incidents and retrospectives."
    },
    {
      "from": "economics",
      "to": "core",
      "mode": "costs",
      "allowed": true,
      "reason": "workflow budgeting constrains execution."
    },
    {
      "from": "gitops",
      "to": "core",
      "mode": "governs",
      "allowed": true,
      "reason": "versioning and commit discipline govern changes to the kit."
    }
  ],
  "workflow": {
    "phases": [
      "intake",
      "elicitation",
      "architecture",
      "documentation",
      "testing",
      "implementation",
      "refactor",
      "review",
      "release",
      "learning"
    ],
    "entry": "intake",
    "exit": "archived",
    "gates": [
      "validation",
      "security",
      "decision",
      "budget",
      "telemetry",
      "evidence_bundle"
    ]
  },
  "artifact_lifecycle": {
    "states": [
      "draft",
      "reviewed",
      "approved",
      "archived"
    ],
    "transitions": [
      {
        "from": "draft",
        "to": "reviewed",
        "requires": [
          "owner_assigned",
          "minimum_structure_present"
        ]
      },
      {
        "from": "reviewed",
        "to": "approved",
        "requires": [
          "validation_passed",
          "evidence_bundle_present",
          "security_checked",
          "decision_record_present"
        ]
      },
      {
        "from": "approved",
        "to": "archived",
        "requires": [
          "version_tagged",
          "trace_recorded"
        ]
      }
    ],
    "promotion_rule": "Artifacts may move from planning_artifacts/ to docs/ only after reviewed and approved states are satisfied."
  },
  "decision_framework": {
    "template": "governance/decision/decision-template.md",
    "criteria": [
      "cost",
      "benefit",
      "reversibility",
      "systemic_impact",
      "risk",
      "time_to_implement",
      "maintainability",
      "auditability"
    ]
  },
  "security": {
    "threat_model": "security/threat-model.md",
    "trust_boundaries": [
      "external_input_to_system",
      "planning_artifacts_to_canonical_state",
      "agent_local_context_to_shared_state",
      "shared_state_to_approved_artifacts",
      "runtime_telemetry_to_learning"
    ],
    "agent_permissions": "security/agent-permissions.schema.json"
  },
  "observability": {
    "events_schema": "runtime/telemetry/events.schema.json",
    "metrics": [
      "contract_compliance",
      "planning_execution_drift",
      "review_latency_ms",
      "retry_count",
      "token_usage",
      "trace_completeness"
    ],
    "traces": "runtime/telemetry/traces.md"
  },
  "economics": {
    "budget_schema": "governance/economics/execution-budget.schema.json",
    "cost_model": "governance/economics/cost-model.md",
    "budget_controls": [
      "soft_limit_warning",
      "hard_limit_block",
      "approval_over_threshold",
      "drift_based_review"
    ]
  },
  "gitops": {
    "semantic_versioning": "governance/gitops/semantic-versioning.md",
    "conventional_commits": "governance/gitops/conventional-commits.md",
    "gitflow": "governance/gitops/gitflow.md"
  },
  "learning": {
    "incidents": "learning/incidents",
    "retrospectives": "learning/retrospectives",
    "pattern_evolution": "learning/pattern-evolution.md"
  },
  "meta_model": {
    "schema": "governance.meta.schema.json",
    "example": "governance.meta.example.json",
    "system_consistency": "meta-model/system-consistency.md",
    "validator": "validator_v3.py"
  }
}