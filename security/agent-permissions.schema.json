{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentPermissions",
  "type": "object",
  "required": [
    "roles"
  ],
  "properties": {
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "role",
          "permission_level",
          "can_read",
          "can_write",
          "can_execute_tools",
          "trust_boundary",
          "approval_required_for"
        ],
        "properties": {
          "role": {
            "type": "string"
          },
          "permission_level": {
            "type": "string",
            "enum": [
              "read-only",
              "limited-write",
              "orchestrator",
              "reviewer",
              "approver"
            ]
          },
          "can_read": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "can_write": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "can_execute_tools": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "trust_boundary": {
            "type": "string"
          },
          "approval_required_for": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "forbidden_actions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "data_classes_allowed": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}