{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RuntimeTelemetryEvent",
  "type": "object",
  "required": [
    "timestamp",
    "event_type",
    "system",
    "run_id",
    "task_id",
    "actor",
    "phase",
    "severity"
  ],
  "properties": {
    "timestamp": {
      "type": "string"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "decision_recorded",
        "contract_validated",
        "contract_violation",
        "artifact_promoted",
        "artifact_rejected",
        "gate_passed",
        "gate_failed",
        "review_requested",
        "review_completed",
        "state_merged",
        "state_rejected",
        "snapshot_created",
        "snapshot_restored",
        "telemetry_anomaly",
        "human_intervention_required",
        "intervention_triggered",
        "intervention_reason",
        "intervention_role",
        "intervention_outcome",
        "react_observed",
        "react_reasoned",
        "react_action_started",
        "react_action_completed",
        "react_verified",
        "react_blocked",
        "sot_outline_created",
        "sot_section_expanded",
        "sot_structure_validated",
        "sot_artifact_refined",
        "tot_branch_created",
        "tot_branch_scored",
        "tot_branch_pruned",
        "tot_branch_selected",
        "tot_decision_recorded"
      ]
    },
    "system": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "actor": {
      "type": "object",
      "required": [
        "kind",
        "name"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "agent",
            "human",
            "service"
          ]
        },
        "name": {
          "type": "string"
        }
      }
    },
    "phase": {
      "type": "string",
      "enum": [
        "intake",
        "elicitation",
        "architecture",
        "documentation",
        "testing",
        "implementation",
        "refactor",
        "review",
        "release",
        "archived"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "debug",
        "info",
        "notice",
        "warning",
        "error",
        "critical"
      ]
    },
    "contract_id": {
      "type": "string"
    },
    "artifact_id": {
      "type": "string"
    },
    "state_version": {
      "type": "integer",
      "minimum": 1
    },
    "decision": {
      "type": "object"
    },
    "validation": {
      "type": "object"
    },
    "metrics": {
      "type": "object"
    },
    "context": {
      "type": "object"
    },
    "details": {
      "type": "object"
    }
  },
  "additionalProperties": true
}