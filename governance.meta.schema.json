{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/agenops.meta.schema.v3.json",
  "title": "AgenOpsMetaModelV3",
  "type": "object",
  "required": [
    "meta_version",
    "system",
    "layers",
    "skills",
    "invariants",
    "relationships",
    "workflow",
    "artifact_lifecycle",
    "decision_framework",
    "security",
    "observability",
    "economics",
    "gitops",
    "learning",
    "meta_model"
  ],
  "properties": {
    "meta_version": {
      "type": "string",
      "pattern": "^3\\.0\\.0$"
    },
    "system": {
      "type": "object",
      "required": [
        "name",
        "purpose",
        "owner_role"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        },
        "owner_role": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "layers": {
      "type": "object",
      "required": [
        "core",
        "skills",
        "state",
        "runtime",
        "validation",
        "security",
        "judging",
        "experience",
        "templates",
        "policies",
        "topology",
        "decision",
        "telemetry",
        "economics",
        "gitops",
        "learning",
        "meta_model"
      ],
      "properties": {
        "core": {
          "type": "object"
        },
        "skills": {
          "type": "object"
        },
        "state": {
          "type": "object"
        },
        "runtime": {
          "type": "object"
        },
        "validation": {
          "type": "object"
        },
        "security": {
          "type": "object"
        },
        "judging": {
          "type": "object"
        },
        "experience": {
          "type": "object"
        },
        "templates": {
          "type": "object"
        },
        "policies": {
          "type": "object"
        },
        "topology": {
          "type": "object"
        },
        "decision": {
          "type": "object"
        },
        "telemetry": {
          "type": "object"
        },
        "economics": {
          "type": "object"
        },
        "gitops": {
          "type": "object"
        },
        "learning": {
          "type": "object"
        },
        "meta_model": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "skills": {
      "type": "object",
      "required": [
        "manifest",
        "contract",
        "catalog"
      ],
      "properties": {
        "manifest": {
          "type": "string"
        },
        "contract": {
          "type": "string"
        },
        "catalog": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "invariants": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "statement",
          "severity",
          "enforcement",
          "evidence_required"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "statement": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "info",
              "warning",
              "error",
              "critical"
            ]
          },
          "enforcement": {
            "type": "string"
          },
          "evidence_required": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to",
          "mode",
          "allowed",
          "reason"
        ],
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "mode": {
            "type": "string",
            "enum": [
              "reads",
              "writes",
              "validates",
              "governs",
              "orchestrates",
              "advises",
              "routes",
              "observes",
              "costs",
              "learns",
              "deploys"
            ]
          },
          "allowed": {
            "type": "boolean"
          },
          "reason": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "workflow": {
      "type": "object",
      "required": [
        "phases",
        "entry",
        "exit",
        "gates"
      ],
      "properties": {
        "phases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "entry": {
          "type": "string"
        },
        "exit": {
          "type": "string"
        },
        "gates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "artifact_lifecycle": {
      "type": "object",
      "required": [
        "states",
        "transitions",
        "promotion_rule"
      ],
      "properties": {
        "states": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "transitions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "from",
              "to",
              "requires"
            ],
            "properties": {
              "from": {
                "type": "string"
              },
              "to": {
                "type": "string"
              },
              "requires": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          }
        },
        "promotion_rule": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "decision_framework": {
      "type": "object",
      "required": [
        "template",
        "criteria"
      ],
      "properties": {
        "template": {
          "type": "string"
        },
        "criteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "security": {
      "type": "object",
      "required": [
        "threat_model",
        "trust_boundaries",
        "agent_permissions"
      ],
      "properties": {
        "threat_model": {
          "type": "string"
        },
        "trust_boundaries": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "agent_permissions": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "observability": {
      "type": "object",
      "required": [
        "events_schema",
        "metrics",
        "traces"
      ],
      "properties": {
        "events_schema": {
          "type": "string"
        },
        "metrics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "traces": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "economics": {
      "type": "object",
      "required": [
        "budget_schema",
        "cost_model",
        "budget_controls"
      ],
      "properties": {
        "budget_schema": {
          "type": "string"
        },
        "cost_model": {
          "type": "string"
        },
        "budget_controls": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "gitops": {
      "type": "object",
      "required": [
        "semantic_versioning",
        "conventional_commits",
        "gitflow"
      ],
      "properties": {
        "semantic_versioning": {
          "type": "string"
        },
        "conventional_commits": {
          "type": "string"
        },
        "gitflow": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "learning": {
      "type": "object",
      "required": [
        "incidents",
        "retrospectives",
        "pattern_evolution"
      ],
      "properties": {
        "incidents": {
          "type": "string"
        },
        "retrospectives": {
          "type": "string"
        },
        "pattern_evolution": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "meta_model": {
      "type": "object",
      "required": [
        "schema",
        "example",
        "system_consistency",
        "validator"
      ],
      "properties": {
        "schema": {
          "type": "string"
        },
        "example": {
          "type": "string"
        },
        "system_consistency": {
          "type": "string"
        },
        "validator": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}